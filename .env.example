# MIAGE 2026 Lab - Secrets
# Copy to .env and fill in real values: cp .env.example .env

# Authentik
AUTHENTIK_SECRET_KEY=generate-with-openssl-rand-base64-48
AUTHENTIK_PG_PASSWORD=change-me
AUTHENTIK_BOOTSTRAP_PASSWORD=change-me
AUTHENTIK_BOOTSTRAP_TOKEN=change-me

# Teleport GitHub OAuth
GITHUB_OAUTH_CLIENT_ID=from-github-oauth-app
GITHUB_OAUTH_CLIENT_SECRET=from-github-oauth-app
